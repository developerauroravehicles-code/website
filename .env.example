# PostgreSQL (required locally and on Vercel). SQLite file URLs do not work on Vercel serverless.
# Example local: postgresql://USER:PASSWORD@localhost:5432/aurora?schema=public
# Example Neon: postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aurora?schema=public"

AUTH_SECRET="replace-with-at-least-32-random-characters-long-secret"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"

# Local dev: http://localhost:3000 — Production: https://your-domain.com (used for metadata / OG URLs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Vercel ---
# 1. Create a Postgres DB (Neon, Supabase, or Vercel Postgres) and set DATABASE_URL in Project → Settings → Environment Variables (Production + Preview).
# 2. Set AUTH_SECRET, ADMIN_*, NEXT_PUBLIC_SITE_URL to production values.
# 3. Build runs: prisma migrate deploy && next build (applies prisma/migrations to the DB).
# 4. Optional: after first deploy, run `npx prisma db seed` locally against production DATABASE_URL or add a one-off script.
