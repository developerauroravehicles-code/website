# PostgreSQL (required locally and on Vercel). SQLite file URLs do not work on Vercel serverless.
# Example local: postgresql://USER:PASSWORD@localhost:5432/aurora?schema=public
# Example Neon: postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aurora?schema=public"

AUTH_SECRET="replace-with-at-least-32-random-characters-long-secret"
# Admin login (must match what you type on /admin/login). Created by: npm run db:seed or npm run db:seed:admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"

# Local dev: http://localhost:3000 — Production: https://your-domain.com (used for metadata / OG URLs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google reCAPTCHA v3 for /admin/login (create keys at https://www.google.com/recaptcha/admin — choose v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# Optional: minimum score 0.0–1.0 (default 0.5). Lower only if legitimate users get blocked.
# RECAPTCHA_MIN_SCORE="0.5"

# --- Vercel (required for build) ---
# DATABASE_URL must exist before `npm run build` — add it under Settings → Environment Variables.
# Enable the variable for the environments you deploy (at minimum: Production + Preview), then Redeploy.
# Without it, Prisma fails with P1012 / "Environment variable not found: DATABASE_URL".
# 1. Create Postgres (Neon, Supabase, Vercel Postgres, etc.) and paste the connection string as DATABASE_URL.
# 2. Also set AUTH_SECRET, ADMIN_*, NEXT_PUBLIC_SITE_URL for production.
# 3. Build: prisma migrate deploy applies prisma/migrations; then next build.
# 4. Optional: npx prisma db seed (with production DATABASE_URL in env) for initial admin/products.
